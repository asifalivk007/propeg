# Secrets — NEVER commit. Copy umami_config.example.php and fill in locally.
umami_config.php

# Runtime caches holding visitor location data (regenerated by globe-data.php)
globe_cache.json
city_coords.json

# Ignore temporary query files (async job artifacts: .request.json/.fa/.result/.json/.log)
query/

# Ad-hoc diagnostics
sleeptest.php

# Ignore node_modules and build output in visualization-react
visualization-react/node_modules/
visualization-react/dist/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/

# Data directory (if contains sensitive data)
# data/

# Ignore local Python caches and venvs
__pycache__/
ext_tools/PRIDICT2/venv/
# Ignore PRIDICT2 prediction outputs but keep the directory: the script writes
# its CSVs here and never creates the folder itself, so a clone needs it present.
ext_tools/PRIDICT2/predictions/*
!ext_tools/PRIDICT2/predictions/.gitkeep
ext_tools/PRIDICT2/__pycache__/
ext_tools/peglit/venv/
ext_tools/peglit/__pycache__/
.claude/
